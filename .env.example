# =============================================
# DASH3 — Variables de Entorno Requeridas
# Copia este archivo a .env.local y completa los valores
# NUNCA subas .env.local a Git
# =============================================

# URL de tu Google Apps Script (Web App)
# Ve a Extensions > Apps Script > Deploy > Manage Deployments > copiar la URL
VITE_GAS_URL=https://script.google.com/macros/s/TU_SCRIPT_ID/exec

# Salt secreto para firmas HMAC-SHA256 en los códigos QR
# Genera uno aleatorio: openssl rand -hex 32
VITE_HMAC_SALT=cambia_esto_por_un_valor_aleatorio_largo

# Hash SHA256 del PIN de administrador
# Para generar: en la consola del browser: CryptoJS.SHA256("tu_pin").toString()
# Ejemplo con PIN "5678": e22d0cf9c1b7a1028c6f67cfffd5dac77399ded26abe85d33c3e3b26b4a2d3c
VITE_ADMIN_PIN_HASH=reemplaza_con_el_hash_de_tu_pin
